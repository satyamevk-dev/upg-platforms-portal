{
  "name": "htd-linux-networking-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "WATCHPACK_POLLING=true next dev --webpack --hostname 127.0.0.1",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:sync:push": "bash scripts/db-sync-push.sh",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "package:deploy": "bash scripts/package-deployment.sh",
    "docker:deploy": "docker compose -f deploy/docker-compose.yml --env-file deploy/stack.env up -d --build",
    "docker:down": "docker compose -f deploy/docker-compose.yml --env-file deploy/stack.env down"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^3.0.2",
    "next": "16.2.4",
    "next-auth": "^4.24.14",
    "nodemailer": "^7.0.13",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prisma": "^6.19.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
