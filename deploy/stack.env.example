# Copy to deploy/stack.env before first Docker deploy:
#   cp deploy/stack.env.example deploy/stack.env
# Then set NEXTAUTH_SECRET (e.g. openssl rand -base64 32) and POSTGRES_PASSWORD.

POSTGRES_USER=htd
POSTGRES_PASSWORD=change-me
POSTGRES_DB=htd_training

DATABASE_URL=postgresql://htd:change-me@postgres:5432/htd_training

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-use-openssl-rand-base64-32

# Optional: seed script
# SUPER_ADMIN_PASSWORD=
