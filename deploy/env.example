# Copy to repository root as `.env` and adjust values.
# Use with: docker compose -f deploy/docker-compose.yml --env-file .env up -d --build

# PostgreSQL (docker-compose postgres service)
POSTGRES_USER=htd
POSTGRES_PASSWORD=change-me
POSTGRES_DB=htd_training

# Prisma / app — must reach the `postgres` service from containers
# Example when using the bundled compose stack:
DATABASE_URL=postgresql://htd:change-me@postgres:5432/htd_training

# NextAuth (required in production)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Optional: transactional email (portal invites, etc.)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=

# Optional: published origin for links in emails
# APP_ORIGIN=http://localhost:3000

# Optional: host port for the app (default 3000)
# APP_PORT=3000
